# ────────────────────────────────────────────────────────────────────────────
#  AutoNews – Variables de entorno
#  Copiar a .env y completar con valores reales
# ────────────────────────────────────────────────────────────────────────────

# Clave secreta para firmar sesiones (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esto-por-una-clave-segura

# Clave de cifrado para campos sensibles en base de datos
# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=cambia-esto-por-una-fernet-key

# Contraseña inicial del administrador (se crea al arrancar por primera vez)
ADMIN_PASSWORD=admin123

# Base de datos (SQLite por defecto)
DATABASE_URL=sqlite:///./autonews.db

# Host y puerto del servidor web
HOST=0.0.0.0
PORT=8000

# Google Drive API Key (opcional) — permite extraer imágenes de carpetas públicas de Drive
# Crear en: console.cloud.google.com → APIs y servicios → Credenciales
GOOGLE_DRIVE_API_KEY=
